# =============================================================================
# Banka-2 Infrastructure — Kubernetes Secrets (namespace: banka-2)
# =============================================================================
# OVO JE TEMPLATE (.example). NE primenjuj ga sa REPLACE_ME vrednostima i NIKAD
# ne commituj realne vrednosti u git.
#
# WORKFLOW PRI DEPLOY-u (Luka / DevOps):
#   1) Kopiraj ovaj fajl u `secrets.yaml` (koji je u .gitignore):
#        cp secrets.yaml.example secrets.yaml
#   2) Popuni SVE `REPLACE_ME-*` placeholder-e pravim vrednostima
#      (generisi ih openssl-om — vidi komentare uz svaki Secret).
#   3) `kubectl apply -f secrets.yaml -n banka-2` PRE deploy-a Deployment-a
#      (Deployment-i citaju ove Secret-e preko secretKeyRef-a; bez njih pod ne
#      startuje — env var se ne resolve-uje).
#
# ALTERNATIVA (preferirano za produkciju — vrednosti uopste ne dodiruju disk):
#   kubectl create secret generic <ime> --from-literal=KEY="$(openssl rand ...)" -n banka-2
#   (komande su navedene u komentaru uz svaki Secret ispod).
#
# NAPOMENA: Crunchy PostgreSQL kredencijali NISU ovde — PG operator ih
# auto-generise u Secret-e `db-pguser-db` i `db-pguser-trading-db`, koje
# Deployment-i i seed Job-ovi vec citaju preko secretKeyRef-a. Ne diramo ih.
# =============================================================================
---
# -----------------------------------------------------------------------------
# app-secrets — deljeni inter-service secret-i (banka-core + trading-service).
#   JWT_SECRET        : HS256 potpis (min 256-bit base64). Deljen izmedju servisa
#                       koji verifikuju isti token. Forge-able ako procuri.
#   INTERNAL_API_KEY  : X-Internal-Key za /internal/** money seam
#                       (banka-core <-> trading-service). MORA biti identicna
#                       vrednost u oba servisa.
#   PARTNER1_INBOUND_TOKEN / PARTNER1_OUTBOUND_TOKEN : inter-bank (Tim 1)
#                       handshake tokeni (X-Api-Key smer ka/od partnera).
#
# Kreiraj sa:
#   kubectl create secret generic app-secrets \
#     --from-literal=JWT_SECRET="$(openssl rand -base64 64)" \
#     --from-literal=INTERNAL_API_KEY="$(openssl rand -hex 32)" \
#     --from-literal=PARTNER1_INBOUND_TOKEN="dev-outbound-banka1-to-banka2" \
#     --from-literal=PARTNER1_OUTBOUND_TOKEN="dev-inbound-banka2-to-banka1" \
#     -n banka-2
#
# DEV/DEMO: gornje dev vrednosti se VEC poklapaju sa Banka 1 repo-om (oba tima
# shipuju iste dev tokene), pa cross-bank radi out-of-the-box cim se oba podignu:
#   PARTNER1_INBOUND_TOKEN  = sto Banka 1 SALJE nama (njihov outbound) = dev-outbound-banka1-to-banka2
#   PARTNER1_OUTBOUND_TOKEN = sto MI saljemo Banci 1 (njihov inbound)  = dev-inbound-banka2-to-banka1
# PROD: zamenite oba para jednim jakim (>=32) zajednickim tokenom, dogovorno na obe strane,
# i rotirajte (stari dev tokeni su u git istoriji — vidi SECRETS.md §3).
# -----------------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: banka-2
type: Opaque
stringData:
  JWT_SECRET: "REPLACE_ME-jwt-openssl-rand-base64-64"
  INTERNAL_API_KEY: "REPLACE_ME-internal-api-key-openssl-rand-hex-32"
  # Inter-bank (Banka 1) tokeni. DEV vrednosti dole se poklapaju sa Banka 1 repo-om →
  # cross-bank radi out-of-the-box. Za PROD rotiraj na jak zajednicki token (vidi komentar gore).
  PARTNER1_INBOUND_TOKEN: "dev-outbound-banka1-to-banka2"
  PARTNER1_OUTBOUND_TOKEN: "dev-inbound-banka2-to-banka1"
---
# -----------------------------------------------------------------------------
# influxdb-credentials — InfluxDB 2.x bootstrap admin + write token.
#   INFLUX_ADMIN_USERNAME : UI login (port 8086, /signin).
#   INFLUX_ADMIN_PASSWORD : UI login lozinka.
#   INFLUX_ADMIN_TOKEN    : init admin token + trading-service write API.
#                           MORA biti min 32 bajta (zahtevano za init).
#
# Kreiraj sa:
#   kubectl create secret generic influxdb-credentials \
#     --from-literal=INFLUX_ADMIN_USERNAME="banka2-admin" \
#     --from-literal=INFLUX_ADMIN_PASSWORD="$(openssl rand -hex 16)" \
#     --from-literal=INFLUX_ADMIN_TOKEN="$(openssl rand -hex 32)" \
#     -n banka-2
# -----------------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: influxdb-credentials
  namespace: banka-2
type: Opaque
stringData:
  INFLUX_ADMIN_USERNAME: "REPLACE_ME-influx-admin-username"
  INFLUX_ADMIN_PASSWORD: "REPLACE_ME-influx-admin-password-openssl-rand-hex-16"
  INFLUX_ADMIN_TOKEN: "REPLACE_ME-influx-admin-token-openssl-rand-hex-32-min-32-bytes"
---
# -----------------------------------------------------------------------------
# rabbitmq-credentials — dedicated RabbitMQ user (zamenjuje guest/guest).
#   RABBITMQ_DEFAULT_USER : broker default user; isti za broker i sve consumere
#                           (banka-core, trading-service, notification-service).
#   RABBITMQ_DEFAULT_PASS : lozinka.
#
# Kreiraj sa:
#   kubectl create secret generic rabbitmq-credentials \
#     --from-literal=RABBITMQ_DEFAULT_USER="banka2" \
#     --from-literal=RABBITMQ_DEFAULT_PASS="$(openssl rand -hex 16)" \
#     -n banka-2
# -----------------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-credentials
  namespace: banka-2
type: Opaque
stringData:
  RABBITMQ_DEFAULT_USER: "banka2"
  RABBITMQ_DEFAULT_PASS: "REPLACE_ME-rabbitmq-pass-openssl-rand-hex-16"
---
# -----------------------------------------------------------------------------
# mail-credentials — Gmail SMTP za notification-service.
#   MAIL_USERNAME : Gmail nalog (npr. banka2.notifications@gmail.com).
#   MAIL_PASSWORD : Gmail "App password" (16-char, zahteva 2FA), NE regular pwd.
#                   Bez ovoga SMTP tiho fail-uje (prazan pwd) — vidi
#                   notification-service.yaml.
#                   Generisanje: https://myaccount.google.com/apppasswords
#
# Kreiraj sa:
#   kubectl create secret generic mail-credentials \
#     --from-literal=MAIL_USERNAME="banka2.notifications@gmail.com" \
#     --from-literal=MAIL_PASSWORD="xxxx xxxx xxxx xxxx" \
#     -n banka-2
# -----------------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: mail-credentials
  namespace: banka-2
type: Opaque
stringData:
  MAIL_USERNAME: "REPLACE_ME-gmail-username"
  MAIL_PASSWORD: "REPLACE_ME-gmail-app-password"
